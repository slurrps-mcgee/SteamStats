# Steam Web API key (https://steamcommunity.com/dev/apikey). Required.
# Never commit your real key or expose it to the frontend.
STEAM_API_KEY=your_steam_api_key_here

# Origin the backend accepts CORS requests from. Should match wherever the
# frontend is actually served from (the browser's origin).
FRONTEND_ORIGIN=http://localhost:8080

# Rate limiting (protects your Steam Web API quota).
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
