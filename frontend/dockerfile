# syntax=docker/dockerfile:1

# --- Build stage --------------------------------------------------------
FROM node:22-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
COPY shared/package.json shared/package.json
COPY backend/package.json backend/package.json
COPY frontend/package.json frontend/package.json
RUN npm ci

COPY shared shared
COPY frontend/ frontend/
RUN npm run build --workspace=@steamstats/shared
RUN npm run build --workspace=frontend -- --configuration production

# --- Runtime stage --------------------------------------------------------
# Serves the compiled static SPA and reverse-proxies /api to the backend
# container over the internal Docker network. The backend itself is never
# published to the host - only this nginx server is.
FROM nginx:1.27-alpine AS runtime

COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/frontend/dist/steamstats/browser /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
